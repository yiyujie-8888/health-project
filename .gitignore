cat > .gitignore << 'EOF'
# 依赖
node_modules/
npm-debug.log*
yarn-error.log*
.pnpm-store/

# 环境变量
.env
.env.local
.env.*.local

# 编辑器
.vscode/
.idea/
.DS_Store
*.swp
*.swo

# 后端
health-backend/target/
health-backend/*.iml
health-backend/.mvn/

# AI 模型大文件
health-ai/weights/
health-ai/*.pth
health-ai/*.bin
health-ai/*.ckpt
health-ai/*.onnx
EOF